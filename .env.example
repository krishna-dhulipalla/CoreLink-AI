# CoreLink AI: External Configuration
# Use this template to set up your environment variables.
# Copy to `.env` and configure with your service keys.

# ---------------------------------------------------------------------------
# Provider Access
# ---------------------------------------------------------------------------
# Primary OpenAI-compatible API key (OpenAI, Nebius, Groq, etc.)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=

# Tavily search for the built-in internet_search tool
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# Model Selection & Profiles
# ---------------------------------------------------------------------------
# Profiles: custom, oss_debug, cheap, balanced, score_max, officeqa
MODEL_PROFILE=officeqa

# Structured Output Mode (auto, native, local_json)
STRUCTURED_OUTPUT_MODE=auto

# Global fallback model name
MODEL_NAME=deepseek-ai/DeepSeek-V3.2

# Specialized role-based model selection (optional)
DIRECT_MODEL=
SOLVER_MODEL=
REVIEWER_MODEL=
PROFILER_MODEL=
ADAPTER_MODEL=
REFLECTION_MODEL=

# OfficeQA-specific strong overrides (recommended when available)
DOCUMENT_SOLVER_MODEL=
LONG_CONTEXT_SOLVER_MODEL=
DOCUMENT_REVIEWER_MODEL=
LONG_CONTEXT_MODEL=

# ---------------------------------------------------------------------------
# MCP Server Integration
# ---------------------------------------------------------------------------
# HTTP: name=url pairs, comma-separated
MCP_SERVER_URLS=

# STDIO: name=command:arg1:arg2 pairs, comma-separated
MCP_SERVER_STDIO=

# ---------------------------------------------------------------------------
# Runtime & ACE Context
# ---------------------------------------------------------------------------
MAX_TOOL_CALLS=15
MAX_REVISE_CYCLES=3
MAX_CONTEXT_TOKENS=80000
ACE_SANDBOX_ENABLED=true
COMPETITION_MODE=0
BENCHMARK_NAME=
BENCHMARK_STATELESS=0
ENABLE_RUN_TRACER=0
TRACE_MAX_RECENT=5

# OfficeQA corpus packaging
OFFICEQA_CORPUS_DIR=
OFFICEQA_INDEX_DIR=

# ---------------------------------------------------------------------------
# Persistence & Memory
# ---------------------------------------------------------------------------
MEMORY_DB_PATH=src/data/agent_memory.db
ENABLE_AGENT_MEMORY=0
CONVERSATION_TTL_SECONDS=3600
