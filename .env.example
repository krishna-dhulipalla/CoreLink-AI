# CoreLink AI example environment
# Copy to `.env` and replace placeholder values.

# ---------------------------------------------------------------------------
# OpenAI-compatible API access
# ---------------------------------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=

# Tavily search for the built-in internet_search tool
TAVILY_API_KEY=

# ---------------------------------------------------------------------------
# Model selection
# Presets: custom, oss_debug, cheap, balanced, score_max
# ---------------------------------------------------------------------------
MODEL_PROFILE=custom

# Global fallback model when a role-specific model is not set
MODEL_NAME=openai/gpt-oss-20b

# Optional per-role overrides
COORDINATOR_MODEL=gpt-4.1-mini
DIRECT_MODEL=gpt-4o-mini
EXECUTOR_MODEL=gpt-4.1
VERIFIER_MODEL=gpt-4.1-mini
FORMATTER_MODEL=gpt-4o-mini
REFLECTOR_MODEL=gpt-4o-mini

# Optional per-role OpenAI-compatible routing
# Example: point only the executor to a local or alternative endpoint
COORDINATOR_OPENAI_API_KEY=
COORDINATOR_OPENAI_BASE_URL=
DIRECT_OPENAI_API_KEY=
DIRECT_OPENAI_BASE_URL=
EXECUTOR_OPENAI_API_KEY=
EXECUTOR_OPENAI_BASE_URL=
VERIFIER_OPENAI_API_KEY=
VERIFIER_OPENAI_BASE_URL=
FORMATTER_OPENAI_API_KEY=
FORMATTER_OPENAI_BASE_URL=
REFLECTOR_OPENAI_API_KEY=
REFLECTOR_OPENAI_BASE_URL=

# ---------------------------------------------------------------------------
# MCP server discovery
# HTTP:  name=url pairs, comma-separated
# STDIO: name=command:arg1:arg2 pairs, comma-separated
# ---------------------------------------------------------------------------
MCP_SERVER_URLS=
# Example:
# MCP_SERVER_URLS=mock=http://127.0.0.1:3001/mcp,doc=http://127.0.0.1:3010/mcp

MCP_SERVER_STDIO=
# Example:
# MCP_SERVER_STDIO=mock=python:src/mock_mcp_server.py

# ---------------------------------------------------------------------------
# Runtime budgets and loop control
# ---------------------------------------------------------------------------
MAX_TOOL_CALLS=15
MAX_REVISE_CYCLES=3
MAX_BACKTRACK_CYCLES=2
MAX_HINT_TOKENS=200
MAX_REFLECTIONS=2

# ---------------------------------------------------------------------------
# Context management
# ---------------------------------------------------------------------------
MAX_CONTEXT_TOKENS=80000
MAX_TOOL_OUTPUT_CHARS=4000
CONTEXT_KEEP_RECENT=6
TIKTOKEN_MODEL=gpt-oss-20b

# ---------------------------------------------------------------------------
# Multi-turn conversation retention
# ---------------------------------------------------------------------------
CONVERSATION_TTL_SECONDS=3600

# ---------------------------------------------------------------------------
# Execution memory
# ---------------------------------------------------------------------------
MEMORY_DB_PATH=src/data/agent_memory.db
MEMORY_MAX_RECORDS=500
MEMORY_TOP_K=3
MEMORY_DEDUP_WINDOW=3600

# ---------------------------------------------------------------------------
# Document analytics MCP cache
# ---------------------------------------------------------------------------
DOC_ANALYTICS_MAX_TABLES=200
DOC_ANALYTICS_TABLE_TTL=1800
