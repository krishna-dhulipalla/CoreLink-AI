# CoreLinkAI local OfficeQA template

MODEL_PROFILE=officeqa

# Provider access
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional Nebius fallback for the officeqa profile
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Optional search
TAVILY_API_KEY=

# Role overrides when you want stronger routing
DIRECT_MODEL=
SOLVER_MODEL=
REVIEWER_MODEL=
PROFILER_MODEL=
ADAPTER_MODEL=
REFLECTION_MODEL=
DOCUMENT_SOLVER_MODEL=
DOCUMENT_REVIEWER_MODEL=
LONG_CONTEXT_SOLVER_MODEL=
LONG_CONTEXT_MODEL=
SYNTHESIS_HEAVY_SOLVER_MODEL=
SYNTHESIS_HEAVY_REVIEWER_MODEL=
AMBIGUITY_SOLVER_MODEL=
AMBIGUITY_REVIEWER_MODEL=
FINANCIAL_REASONING_SOLVER_MODEL=

# Runtime
STRUCTURED_OUTPUT_MODE=auto
TOOL_CALL_MODE=auto
COMPETITION_MODE=0
BENCHMARK_NAME=officeqa
BENCHMARK_STATELESS=1
ENABLE_RUN_TRACER=1
TRACE_MAX_RECENT=5
ENABLE_AGENT_MEMORY=0
CONVERSATION_TTL_SECONDS=3600

# Budgeting
MAX_TOOL_CALLS=15
MAX_REVISE_CYCLES=3
MAX_CONTEXT_TOKENS=80000
DOCUMENT_ANALYSIS_MAX_TOOL_CALLS=20
DOCUMENT_ANALYSIS_MAX_CONTEXT_TOKENS=32000
RETRIEVAL_ANALYSIS_MAX_TOOL_CALLS=18
RETRIEVAL_ANALYSIS_MAX_CONTEXT_TOKENS=24000

# Benchmark integration
BENCHMARK_JUDGE_MCP_URL=
ENABLE_JUDGE_MCP_DISCOVERY=1

# Local OfficeQA corpus
OFFICEQA_CORPUS_DIR=data/officeqa/treasury_bulletins_parsed
OFFICEQA_INDEX_DIR=

# Persistence
MEMORY_DB_PATH=src/data/agent_memory.db
